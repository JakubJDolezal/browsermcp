{
  "name": "browsefleetmcp",
  "version": "0.1.3",
  "description": "CLI and MCP server for parallel browser automation with isolated windows and screenshots",
  "author": "Jakub Dolezal",
  "license": "Apache-2.0",
  "homepage": "https://jakubjdolezal.github.io/browsermcp/",
  "bugs": {
    "url": "https://github.com/JakubJDolezal/browsermcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JakubJDolezal/browsermcp.git"
  },
  "keywords": [
    "mcp",
    "browser",
    "chrome-extension",
    "automation",
    "screenshots",
    "multi-agent"
  ],
  "type": "module",
  "bin": {
    "browsefleetmcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "npm run build && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsup src/index.ts --format esm --watch ",
    "inspector": "cross-env CLIENT_PORT=9001 SERVER_PORT=9002 npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "commander": "^13.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "cross-env": "^10.0.0",
    "@types/node": "^24.6.0",
    "@types/ws": "^8.18.0",
    "shx": "^0.3.4",
    "tsup": "^8.4.0",
    "typescript": "^5.6.2"
  }
}
